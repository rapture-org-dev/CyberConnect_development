# DeepL — sheet bilingual auto-translate (server-only)
# API Free keys use https://api-free.deepl.com ; Pro uses https://api.deepl.com
DEEPL_AUTH_KEY=
DEEPL_API_URL=https://api-free.deepl.com
DEEPL_AUTO_TRANSLATE=true

# Supabase (existing app config — copy from your project)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GitHub Issues — create/link/sync from CyberConnect Tasks (server-only)
# Fine-grained PAT: Issues Read and write on the target repo
GITHUB_ISSUES_TOKEN=
GITHUB_OWNER=rapture-org-dev
GITHUB_REPO=CyberConnect_development
# Webhook secret (GitHub repo → Settings → Webhooks)
GITHUB_WEBHOOK_SECRET=
# Required for webhook inbound sync (bypasses RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Discord → GitHub Issue (staging Interactions Endpoint; optional for local)
# DISCORD_PUBLIC_KEY=
# DISCORD_ALLOWED_GUILD_ID=
# DISCORD_ALLOWED_CHANNEL_ID=
